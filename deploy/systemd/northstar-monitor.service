[Unit]
Description=Northstar operational monitor
After=network-online.target northstar.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/northstar/server
EnvironmentFile=/opt/northstar/server/.env
Environment=BACKUP_DIR=/opt/northstar/backups
Environment=HEALTHCHECK_URL=http://127.0.0.1:3001/api/health
ExecStart=/usr/bin/node /opt/northstar/server/scripts/monitor-operations.js
